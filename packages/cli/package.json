{
  "name": "@ploybundle/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ploybundle": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
