{
  "name": "ploybundle",
  "version": "0.1.0",
  "private": true,
  "description": "Project-scoped self-hosted app bundle generator and installer",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "local-dev:stack": "node scripts/materialize-local-stack.mjs",
    "local-dev:up": "node scripts/stack-docker-up.mjs",
    "docker:up": "node scripts/stack-docker-up.mjs",
    "demo:user": "node scripts/user-demo.mjs",
    "verify:control-plane": "node scripts/verify-control-plane.mjs",
    "ci:verify": "pnpm run test && pnpm run verify:control-plane"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
